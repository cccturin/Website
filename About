<!-- STORY -->
<section class="story">
  <div class="container">
    <div class="story-grid">
      <div>
        <span class="accent-line"></span>
        <h2>Who we are.</h2>
      </div>
      <div>
        <p>
          CCC is a small community center in Turin, New York — part house of worship,
          part gathering space, part open door. We host Sunday services, a weekly youth
          group, and we rent our facilities out to neighbors who need a room.
        </p>
        <p>
          We're a <strong>registered 501(c)(3) nonprofit</strong>, and everything we do
          is shaped by the community around us. There's nothing flashy here — just a
          warm, accessible space and people who are glad you stopped by.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- OFFERINGS -->
<section class="offerings-list">
  <div class="container">
    <div class="section-head">
      <div>
        <span class="eyebrow">What we offer</span>
        <h2 style="margin-top:1.2rem;">A few things,<br>done with care.</h2>
      </div>
      <p class="lead">
        Three ways to be part of what happens at CCC — come on Sunday, send
        your kids on Thursday, or borrow the room for your own gathering.
      </p>
    </div>

    <div class="offer-row">
      <span class="num">— 01</span>
      <h3>Sunday Service</h3>
      <p>Join us every Sunday morning at <strong>10:00 AM</strong> for worship and fellowship. No dress code, no expectations — just come as you are.</p>
    </div>

    <div class="offer-row">
      <span class="num">— 02</span>
      <h3>Youth Group Programs</h3>
      <p>Weekly youth group activities designed to help young people build lasting friendships and grow in a supportive environment. <strong>Thursdays, 6:30–8:30 PM</strong>, September through June.</p>
    </div>

    <div class="offer-row">
      <span class="num">— 03</span>
      <h3>Facility Rentals</h3>
      <p>Our gymnasium and facilities are available for community events, meetings, celebrations, and gatherings. We welcome inquiries from local organizations, families, and groups looking for a clean, accessible space in the Turin area.</p>
    </div>
  </div>
</section>

