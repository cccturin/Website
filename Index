<link rel="stylesheet" href="styles.css" />

<style>
  /* =============== HOMEPAGE SPECIFIC =============== */

  /* HERO */
  .home-hero {
    padding: clamp(4rem, 12vh, 9rem) 0 clamp(3rem, 8vh, 6rem);
    position: relative;
    overflow: hidden;
  }

  .home-hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -10%;
    width: 70%;
    height: 140%;
    background: radial-gradient(ellipse at center, rgba(122, 174, 196, 0.22) 0%, rgba(201, 185, 154, 0.12) 40%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .home-hero .container { position: relative; z-index: 1; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 6.2rem);
  }
  .hero-title .italic {
    font-style: italic;
    font-weight: var(--w-light);
    display: block;
    color: var(--sky-blue-deep);
  }

  /* Building card — illustrated hero visual */
  .building-card {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--sandstone);
    box-shadow: 0 30px 60px -30px rgba(92, 68, 50, 0.4),
                0 1px 0 rgba(255,255,255,0.4) inset;
  }
  .building-card svg { display: block; width: 100%; height: 100%; }

  .building-card .badge {
    position: absolute;
    top: 1.3rem;
    left: 1.3rem;
    background: rgba(242, 237, 228, 0.93);
    backdrop-filter: blur(6px);
    color: var(--ink);
    padding: 0.55rem 0.9rem;
    border-radius: 100px;
    font-size: 0.72rem;
    font-weight: var(--w-med);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .building-card .badge::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--sky-blue);
    border-radius: 50%;
  }

  /* INFO STRIP */
  .info-strip {
    padding: 3.5rem 0;
    border-top: 1px solid rgba(122, 92, 69, 0.14);
    border-bottom: 1px solid rgba(122, 92, 69, 0.14);
    background: rgba(201, 185, 154, 0.14);
  }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  @media (max-width: 780px) {
    .info-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  .info-item { display: flex; flex-direction: column; gap: 0.4rem; }
  .info-item .label {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    font-weight: var(--w-med);
  }
  .info-item .val {
    font-family: var(--font-display);
    font-weight: var(--w-bold);
    font-size: 1.35rem;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .info-item .sub { font-size: 0.9rem; color: var(--ink-soft); }

  /* OFFERINGS — three feature cards */
  .offerings {
    padding: clamp(5rem, 10vh, 8rem) 0;
  }
  .offer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .offer-grid { grid-template-columns: 1fr; }
  }

  .offer-card {
    background: var(--bg-alt);
    border: 1px solid rgba(122, 92, 69, 0.12);
    border-radius: var(--radius-lg);
    padding: 2.4rem 2rem 2.2rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: all 0.5s var(--ease);
  }
  .offer-card:hover {
    transform: translateY(-4px);
    border-color: var(--sky-blue);
    box-shadow: 0 24px 50px -28px rgba(92, 68, 50, 0.35);
  }
  .offer-card .num {
    font-family: var(--font-display);
    font-weight: var(--w-light);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--mist-gray);
    margin-bottom: 2.2rem;
  }
  .offer-card h3 {
    margin-bottom: 0.9rem;
    font-size: 1.65rem;
  }
  .offer-card p {
    color: var(--ink-soft);
    font-size: 0.97rem;
    margin-bottom: 1.8rem;
    flex: 1;
  }
  .offer-card .offer-link {
    font-family: var(--font-body);
    font-weight: var(--w-med);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.3s var(--ease), color 0.3s var(--ease);
  }
  .offer-card .offer-link:hover {
    gap: 0.85rem;
    color: var(--sky-blue-deep);
  }

  /* CTA BAND */
  .cta-band {
    margin-top: 2rem;
    background: var(--warm-brown);
    color: var(--linen);
    border-radius: var(--radius-lg);
    padding: clamp(3rem, 7vw, 5rem) clamp(2rem, 6vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  .cta-band::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 85% 30%, rgba(122, 174, 196, 0.28) 0%, transparent 55%);
    pointer-events: none;
  }
  .cta-band .inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (max-width: 780px) {
    .cta-band .inner { grid-template-columns: 1fr; }
  }
  .cta-band h2 {
    color: var(--linen);
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-bottom: 0.8rem;
  }
  .cta-band p {
    color: var(--sandstone);
    max-width: 520px;
    font-size: 1.05rem;
  }
  .cta-band .btn-accent { justify-self: start; }
  @media (max-width: 780px) { .cta-band .btn-accent { justify-self: stretch; justify-content: center; } }

  /* ============ EVENT PROMO BANNER ============ */
  .event-promo {
    padding: clamp(2rem, 5vh, 3.5rem) 0 0;
  }
  .promo-card {
    background: var(--linen-deep);
    border: 1px solid rgba(122, 92, 69, 0.18);
    border-radius: var(--radius-lg);
    padding: clamp(1.6rem, 3vw, 2.2rem) clamp(1.8rem, 3.5vw, 2.8rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: clamp(1.2rem, 3vw, 2.2rem);
    align-items: center;
    position: relative;
    overflow: hidden;
    transition: all 0.4s var(--ease);
  }
  .promo-card:hover {
    border-color: var(--sky-blue);
    transform: translateY(-2px);
    box-shadow: 0 24px 50px -30px rgba(92, 68, 50, 0.4);
  }
  .promo-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--sky-blue);
  }

  .promo-date {
    background: var(--warm-brown);
    color: var(--linen);
    padding: 1rem 1.3rem;
    border-radius: var(--radius);
    text-align: center;
    min-width: 92px;
  }
  .promo-date .m {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--sandstone);
    font-weight: var(--w-med);
    display: block;
  }
  .promo-date .d {
    font-family: var(--font-display);
    font-weight: var(--w-black);
    font-size: 2.4rem;
    line-height: 1;
    margin: 0.15rem 0 0.1rem;
    letter-spacing: -0.03em;
    display: block;
  }
  .promo-date .wd {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: var(--w-light);
    font-size: 0.82rem;
    color: var(--sky-blue);
    display: block;
  }

  .promo-content .tag {
    font-size: 0.66rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--sky-blue-deep);
    font-weight: var(--w-med);
    display: inline-block;
    margin-bottom: 0.35rem;
  }
  .promo-content h3 {
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    margin-bottom: 0.3rem;
    line-height: 1.15;
  }
  .promo-content p {
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.5;
    max-width: 560px;
  }

  .promo-cta {
    font-family: var(--font-body);
    font-weight: var(--w-med);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.9rem 1.4rem;
    border: 1.5px solid var(--ink);
    border-radius: var(--radius);
    transition: all 0.3s var(--ease);
    white-space: nowrap;
  }
  .promo-cta:hover {
    background: var(--ink);
    color: var(--linen);
    gap: 0.85rem;
  }

  @media (max-width: 780px) {
    .promo-card { grid-template-columns: auto 1fr; }
    .promo-cta { grid-column: 1 / -1; justify-content: center; }
  }
  @media (max-width: 480px) {
    .promo-card { grid-template-columns: 1fr; text-align: center; }
    .promo-date { justify-self: center; }
    .promo-content .tag, .promo-content h3 { display: block; }
  }
</style>
</head>
