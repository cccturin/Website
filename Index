            <defs>
              <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#b8cdd6"/>
                <stop offset="60%" stop-color="#9DAAB0"/>
                <stop offset="100%" stop-color="#c9b99a"/>
              </linearGradient>
              <linearGradient id="wall" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#d9c9a8"/>
                <stop offset="100%" stop-color="#b8a586"/>
              </linearGradient>
              <linearGradient id="roof" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#8a6950"/>
                <stop offset="100%" stop-color="#5c4432"/>
              </linearGradient>
              <linearGradient id="grass" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#a4a887"/>
                <stop offset="100%" stop-color="#7a8068"/>
              </linearGradient>
            </defs>

            <!-- Sky -->
            <rect x="0" y="0" width="400" height="340" fill="url(#sky)"/>

            <!-- Sun -->
            <circle cx="310" cy="90" r="34" fill="#F2EDE4" opacity="0.55"/>
