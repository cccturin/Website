            </g>
            <g>
              <rect x="259" y="260" width="46" height="68" fill="#7AAEC4" opacity="0.75"/>
              <rect x="259" y="260" width="46" height="68" fill="none" stroke="#5c4432" stroke-width="3"/>
              <line x1="282" y1="260" x2="282" y2="328" stroke="#5c4432" stroke-width="2"/>
              <line x1="259" y1="294" x2="305" y2="294" stroke="#5c4432" stroke-width="2"/>
            </g>

